# Development environment configuration
# Copy this file to .env and update with your values
# Or set via: flutter run --dart-define=BASE_URL_DEV=<url>

# API Base URL for dev environment
# Default: https://dev-api.jarvis-helpdesk.com
# Apidog mock example: https://mock.apidog.com/m1/1253730-1250956-default
BASE_URL_DEV=https://dev-api.jarvis-helpdesk.com

# Staging API Base URL
BASE_URL_STAGING=https://staging-api.jarvis-helpdesk.com

# Production API Base URL
BASE_URL_PROD=https://api.jarvis-helpdesk.com

# Sentry DSN for dev environment (optional)
SENTRY_DSN_DEV=

# Sentry DSN for production environment (optional)
SENTRY_DSN_PROD=
