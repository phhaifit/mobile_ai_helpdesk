# Development environment configuration
# Copy this file to .env.local or set values via --dart-define flag

# API Base URL for dev environment
# Default: https://dev-api.jarvis-helpdesk.com
# Example (Apidog mock): https://mock.apidog.com/m1/1253730-1250956-default
BASE_URL_DEV=https://mock.apidog.com/m1/1253730-1250956-default

# Staging API Base URL
BASE_URL_STAGING=https://staging-api.jarvis-helpdesk.com

# Production API Base URL
BASE_URL_PROD=https://api.jarvis-helpdesk.com

# Sentry DSN for dev environment
SENTRY_DSN_DEV=

# Sentry DSN for production environment
SENTRY_DSN_PROD=

# Marketing broadcasting mock toggle.
# When true, the app uses in-memory mocks for marketing broadcast/campaign data.
# Currently the actual switch is the `kUseMarketingMock` const in
# lib/data/di/module/repository_module.dart — flip it to false once the
# backend ships the missing /broadcasts/recipients filters schema,
# /broadcasts/{id}/receipts endpoint, and the realtime status channel.
USE_MOCK_MARKETING=true
